# ============================================
# DevExHost AI Email Marketing Agent - Config
# ============================================

# --- Groq AI (Free) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/devexhost_agent
# OR Atlas: mongodb+srv://user:pass@cluster.mongodb.net/devexhost_agent

# --- SMTP (Email Sending) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=DevExHost Team
SMTP_FROM_EMAIL=noreply@devexhost.com

# --- Telegram Bot (Optional) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- GitHub API (for email hunting) ---
GITHUB_TOKEN=your_github_personal_access_token

# --- App Settings ---
PORT=3000
NODE_ENV=production
BASE_URL=https://devexhost.com

# --- Sending Limits ---
DAILY_SEND_LIMIT=100
MAX_EMAILS_PER_HUNT=200
MIN_DAYS_BETWEEN_EMAILS=5
MAX_FOLLOWUPS=2

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=devexhost2025

# --- Email Open Tracking ---
TRACKING_URL=http://your-vps-ip:3000/track
